{
  "name": "lean-ctx",
  "version": "3.3.6",
  "description": "Context Runtime for AI Agents — compress LLM context by up to 99%. 48 MCP tools, 10 read modes, 90+ shell patterns.",
  "homepage": "https://leanctx.com",
  "repository": "https://github.com/yvgude/lean-ctx",
  "license": "Apache-2.0",
  "install": {
    "command": "curl -fsSL https://leanctx.com/install.sh | sh",
    "alternatives": {
      "cargo": "cargo install lean-ctx",
      "brew": "brew tap yvgude/lean-ctx && brew install lean-ctx",
      "npm": "npm install -g lean-ctx-bin"
    }
  },
  "mcp": {
    "command": "lean-ctx",
    "args": ["--mcp"],
    "env": {}
  },
  "skills": ["skills/lean-ctx"],
  "capabilities": [
    "file-read",
    "file-edit",
    "shell-exec",
    "code-search",
    "semantic-search",
    "session-management",
    "knowledge-base",
    "multi-agent",
    "code-graph"
  ],
  "languages": [
    "rust", "typescript", "javascript", "python", "go", "java",
    "c", "cpp", "csharp", "ruby", "php", "swift", "kotlin",
    "scala", "hcl", "yaml", "toml", "elixir"
  ]
}
