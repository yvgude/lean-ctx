{
  "name": "lean-ctx-client",
  "version": "0.1.0",
  "description": "Thin, dependency-free TypeScript client for the lean-ctx HTTP /v1 contract.",
  "license": "MIT",
  "homepage": "https://leanctx.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yvgude/lean-ctx.git",
    "directory": "cookbook/sdk"
  },
  "keywords": ["lean-ctx", "llm", "context", "mcp", "agent"],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
