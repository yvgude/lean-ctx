<idea-plugin>
    <!-- Optional module: loaded ONLY when org.jetbrains.kotlin is present (IDEA /
      Android Studio). Registers the JVM-PSI-bound StructureProvider implementation
      and the Kotlin K2 declaration. In RustRover/PyCharm this file is never loaded,
      so StructureHandlers / TypeHierarchyResolver / FileStructureScanner are never
      class-loaded → no java-capable / NoClassDefFoundError. -->
    <extensions defaultExtensionNs="com.leanctx.plugin">
        <structureProvider implementation="com.leanctx.plugin.endpoint.StructureHandlers"/>
    </extensions>
    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK2="true"/>
    </extensions>
</idea-plugin>
