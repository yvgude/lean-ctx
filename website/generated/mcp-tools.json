  "schema_version": 1,
  "tools": {
    "granular": [
      {
        "description": "Multi-agent coordination (shared message bus + persistent diaries). Actions: register (join with agent_type+role), post (broadcast or direct message with category), read (poll messages), status (update state: active|idle|finished), handoff (transfer task to another agent with summary), sync (overview of all agents + pending messages + shared contexts), diary (log discovery/decision/blocker/progress/insight — persisted across sessions), recall_diary (read agent diary), diaries (list all agent diaries), list, info.",
        "input_schema": {
          "properties": {
            "action": {
              "description": "Agent operation. diary: persistent log (category=discovery|decision|blocker|progress|insight). recall_diary: read diary. diaries: list all.",
              "enum": [
                "register",
                "list",
                "post",
                "read",
                "status",
                "info",
                "handoff",
                "sync",
                "diary",
                "recall_diary",
                "diaries"
              ],
              "type": "string"
            },
            "agent_type": {
              "description": "Agent type for register (cursor, claude, codex, gemini, crush, subagent)",
              "type": "string"
            },
            "category": {
              "description": "Message category for post (finding, warning, request, status)",
              "type": "string"
            },
            "message": {
              "description": "Message text for post action, or status detail for status action",
              "type": "string"
            },
            "role": {
              "description": "Agent role (dev, review, test, plan)",
              "type": "string"
            },
            "status": {
              "description": "New status for status action",
              "enum": [
                "active",
                "idle",
                "finished"
              ],
              "type": "string"
            },
            "to_agent": {
              "description": "Target agent ID for direct message (omit for broadcast)",
              "type": "string"
            }
          },
          "required": [
            "action"
          ],
          "type": "object"
        },
