{
  "counts": {
    "granular": 42,
    "unified": 5
  },
  "read_modes": {
    "count": 10,
    "modes": [
      "auto",
      "full",
      "map",
      "signatures",
      "diff",
      "aggressive",
      "entropy",
      "task",
      "reference",
      "lines:N-M"
    ]
