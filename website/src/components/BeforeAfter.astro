---

<section class="relative py-20 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8 sm:mb-10">
      <div>
        <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent mb-3">Before & After</p>
        <h2 class="font-display text-2xl sm:text-[2.25rem] font-bold tracking-tight leading-[1.15] text-text-bright">
          Same information. <span class="gradient-text-green">Fraction of the tokens.</span>
        </h2>
      </div>
      <p class="text-[13px] text-muted sm:text-right max-w-xs">Real output from real coding sessions — click to compare.</p>
    </div>

    <div class="flex overflow-x-auto scrollbar-hide -mx-4 px-4 sm:mx-0 sm:px-0 sm:flex-wrap gap-1 sm:gap-1.5 mb-6 sm:mb-8 pb-1" id="demo-tabs">
      {demos.map((d, i) => (
        <button
          data-tab={d.id}
          class:list={[
            'shrink-0 px-3.5 py-2 rounded-lg text-xs font-medium transition-all duration-200 demo-tab cursor-pointer whitespace-nowrap',
            i === 0 ? 'text-accent bg-white/[0.04]' : 'text-muted hover:text-text'
          ]}
        >
          {d.label}
        </button>
      ))}
    </div>

    {demos.map((d, i) => (
      <div
        data-panel={d.id}
        class:list={['demo-panel grid md:grid-cols-2 gap-4 sm:gap-6', i !== 0 && 'hidden']}
      >
        <div>
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-mono text-muted">Without LeanCTX</span>
            <span class="text-xs font-mono text-danger/80">~{d.before.tokens} tokens</span>
          </div>
          <div class="rounded-xl overflow-hidden border border-white/[0.06]">
            <pre class="terminal-body p-4 sm:p-5 text-xs font-mono text-muted leading-relaxed overflow-x-auto max-h-[300px] overflow-y-auto"><code>{d.before.code}</code></pre>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-3">
            <span class="text-xs font-mono text-accent">With LeanCTX</span>
            <span class="text-xs font-mono text-accent">~{d.after.tokens} tokens <span class="text-accent-bright">(-{d.after.saving})</span></span>
          </div>
          <div class="terminal-chrome">
            <pre class="terminal-body p-4 sm:p-5 text-xs font-mono text-text leading-relaxed overflow-x-auto max-h-[300px] overflow-y-auto"><code>{d.after.code}</code></pre>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.demo-tab');
  const panels = document.querySelectorAll('.demo-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('text-accent', 'bg-white/[0.04]');
        t.classList.add('text-muted');
      });
      tab.classList.add('text-accent', 'bg-white/[0.04]');
      tab.classList.remove('text-muted');

      panels.forEach(p => {
        if (p.getAttribute('data-panel') === target) {
          p.classList.remove('hidden');
        } else {
          p.classList.add('hidden');
        }
      });
    });
  });
</script>
