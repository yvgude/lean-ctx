---

<section class="relative py-28 overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-6">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">Live comparison</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-5">See the <span class="text-accent">difference</span></h2>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Real outputs from real projects. Side-by-side, token-counted.
      </p>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-8" id="demo-tabs">
      {demos.map((d, i) => (
        <button
          data-tab={d.id}
          class:list={[
            'px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 demo-tab cursor-pointer',
            i === 0 ? 'bg-accent/10 text-accent border border-accent/20' : 'text-muted hover:text-text hover:bg-surface-2'
          ]}
        >
          {d.label}
        </button>
      ))}
    </div>

    {demos.map((d, i) => (
      <div
        data-panel={d.id}
        class:list={['demo-panel grid md:grid-cols-2 gap-5', i !== 0 && 'hidden']}
      >
        <div class="card-premium rounded-2xl overflow-hidden">
          <div class="flex items-center justify-between px-5 py-3.5 border-b border-border/30">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-danger/60"></span>
              <span class="text-xs font-mono text-danger/80">Without lean-ctx</span>
            </div>
            <span class="text-xs font-mono text-danger/60">~{d.before.tokens} tokens</span>
          </div>
          <pre class="p-5 text-xs font-mono text-muted/70 leading-relaxed overflow-x-auto max-h-[340px] overflow-y-auto"><code>{d.before.code}</code></pre>
        </div>

        <div class="card-premium rounded-2xl overflow-hidden">
          <div class="flex items-center justify-between px-5 py-3.5 border-b border-accent/10">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-full bg-accent/80"></span>
              <span class="text-xs font-mono text-accent/80">With lean-ctx</span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-accent font-semibold">~{d.after.tokens} tokens</span>
              <span class="px-2 py-0.5 rounded-md bg-accent/10 text-xs font-bold text-accent">-{d.after.saving}</span>
            </div>
          </div>
          <pre class="p-5 text-xs font-mono text-text leading-relaxed overflow-x-auto max-h-[340px] overflow-y-auto"><code>{d.after.code}</code></pre>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const tabs = document.querySelectorAll('.demo-tab');
  const panels = document.querySelectorAll('.demo-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');

      tabs.forEach(t => {
        t.classList.remove('bg-accent/10', 'text-accent', 'border', 'border-accent/20');
        t.classList.add('text-muted');
      });
      tab.classList.add('bg-accent/10', 'text-accent', 'border', 'border-accent/20');
      tab.classList.remove('text-muted');

      panels.forEach(p => {
        if (p.getAttribute('data-panel') === target) {
          p.classList.remove('hidden');
        } else {
          p.classList.add('hidden');
        }
      });
    });
  });
</script>
