    title: 'lean-ctx gain',
    subtitle: 'Savings Dashboard',
    savings: 'Persistent',
    description: 'Shows cumulative token savings across all sessions. Persistent stats tracked in ~/.lean-ctx/stats.json. See lifetime ROI at a glance.',
