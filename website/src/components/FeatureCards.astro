---

<section class="relative py-28 overflow-hidden">
  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-20">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">The toolkit</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-5">8 MCP Tools + CLI. <span class="text-accent">One Goal.</span></h2>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Every tool minimizes tokens while maximizing context quality.
        Measured with tiktoken, benchmarked on real projects.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map(f => (
        <div class="card-premium rounded-2xl p-7">
          <div class="flex items-center gap-3.5 mb-5">
            <div class="w-11 h-11 rounded-xl bg-surface-3 border border-border-light/50 flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <Fragment set:html={f.icon} />
              </svg>
            </div>
            <div>
              <h3 class="text-sm font-bold font-mono text-text-bright">{f.title}</h3>
              <p class="text-xs text-muted">{f.subtitle}</p>
            </div>
          </div>
          <p class="text-sm text-muted leading-relaxed mb-5">{f.description}</p>
          <div class="inline-flex items-center px-3 py-1.5 rounded-lg bg-accent/8 border border-accent/10 text-xs font-semibold text-accent">
            {f.savings} savings
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/features" class="btn-outline-glossy inline-flex items-center px-8 py-3.5 text-sm font-medium rounded-xl text-text">
        Explore all tools
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>
  </div>
</section>
