---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-border/50">
  <div class="absolute inset-0 pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-10 mb-12">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-2">
          <svg class="w-6 h-6 shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="7" fill="#0d0d16"/>
            <path d="M6 16L13 9" stroke="#6ee7b7" stroke-width="2.8" stroke-linecap="round"/>
            <path d="M6 16L13 23" stroke="#6ee7b7" stroke-width="2.8" stroke-linecap="round"/>
            <rect x="17" y="10" width="2.2" height="12" rx="1.1" fill="#6ee7b7"/>
            <rect x="22" y="12" width="2.2" height="8" rx="1.1" fill="#6ee7b7" opacity="0.6"/>
            <rect x="27" y="14" width="2.2" height="4" rx="1.1" fill="#6ee7b7" opacity="0.3"/>
          </svg>
          <span class="text-lg font-bold text-text-bright">lean</span>
          <span class="text-lg font-light text-accent -ml-1">-ctx</span>
        </div>
        <p class="text-xs text-muted/40 mb-4 font-mono">lean context · v1.4.0</p>
        <p class="text-sm text-muted leading-relaxed mb-5">
          Hybrid Context Optimizer.<br />
          Reduces LLM token consumption by 89–99%.
        </p>
        <a
          href="https://buymeacoffee.com/yvgude"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-[#FFDD00]/10 border border-[#FFDD00]/20 text-[#FFDD00] text-xs font-medium hover:bg-[#FFDD00]/20 hover:border-[#FFDD00]/40 transition-all duration-300"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c.505-.024.853-.087 1.35-.156.734-.102 1.471-.19 2.209-.28.53-.064 1.074-.098 1.6-.182.488-.078.953-.217 1.405-.422.457-.208.757-.537.905-.996l.088-.455c.025-.132.05-.264.073-.396z"/>
          </svg>
          Buy me a coffee
        </a>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/60 mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="/features" class="text-sm text-muted hover:text-accent transition-colors duration-300">Features</a></li>
          <li><a href="/docs/tools" class="text-sm text-muted hover:text-accent transition-colors duration-300">ctx_read</a></li>
          <li><a href="/docs/tdd" class="text-sm text-muted hover:text-accent transition-colors duration-300">Token Dense Dialect</a></li>
          <li><a href="/docs/dashboard" class="text-sm text-muted hover:text-accent transition-colors duration-300">Dashboard</a></li>
          <li><a href="/docs/cli" class="text-sm text-muted hover:text-accent transition-colors duration-300">CLI Reference</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/60 mb-4">Documentation</h4>
        <ul class="space-y-2.5">
          <li><a href="/docs/getting-started" class="text-sm text-muted hover:text-accent transition-colors duration-300">Getting Started</a></li>
          <li><a href="/docs/installation" class="text-sm text-muted hover:text-accent transition-colors duration-300">Installation</a></li>
