          <li><a href="/docs/token-guide" class="text-sm text-muted hover:text-accent transition-colors duration-300">Token Cost Guide</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/60 mb-4">Community</h4>
        <ul class="space-y-2.5">
          <li><a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors duration-300">GitHub</a></li>
          <li><a href="https://crates.io/crates/lean-ctx" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors duration-300">crates.io</a></li>
          <li><a href="https://github.com/yvgude/lean-ctx/issues" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors duration-300">Issues</a></li>
