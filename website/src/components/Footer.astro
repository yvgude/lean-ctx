---
const year = new Date().getFullYear();
---

<footer class="footer-root">
  <div class="content-grid-wide footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <svg class="footer-logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="7" fill="#0a0a12"/>
            <path d="M6 16L13 9" stroke="#34d399" stroke-width="2.8" stroke-linecap="round"/>
            <path d="M6 16L13 23" stroke="#34d399" stroke-width="2.8" stroke-linecap="round"/>
            <rect x="17" y="10" width="2.2" height="12" rx="1.1" fill="#34d399"/>
            <rect x="22" y="12" width="2.2" height="8" rx="1.1" fill="#34d399" opacity="0.6"/>
            <rect x="27" y="14" width="2.2" height="4" rx="1.1" fill="#34d399" opacity="0.3"/>
          </svg>
          <span class="font-display footer-logo-text">
            <span class="text-text-bright">Lean</span><span class="text-accent">CTX</span>
          </span>
        </a>
        <p class="footer-tagline">
          The Intelligence Layer for AI Coding.
        </p>
      </div>

      <div class="footer-columns">
        <div class="footer-col">
          <h4 class="footer-col-title">Product</h4>
          <ul class="footer-links">
            <li><a href="/how-it-works">How It Works</a></li>
            <li><a href="/mcp-server">Context Server</a></li>
            <li><a href="/shell-hook">Shell Hook</a></li>
            <li><a href="/protocols">Protocols</a></li>
            <li><a href="/cli">CLI Reference</a></li>
            <li><a href="/compatibility">Compatibility</a></li>
            <li><a href="/benchmark">Benchmark</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4 class="footer-col-title">Documentation</h4>
          <ul class="footer-links">
            <li><a href="/docs/getting-started">Getting Started</a></li>
            <li><a href="/docs/configuration">Configuration</a></li>
            <li><a href="/docs/tools">Tool API Reference</a></li>
            <li><a href="/docs/quick-reference">Quick Reference</a></li>
            <li><a href="/docs/tree-sitter">Tree-sitter</a></li>
            <li><a href="/docs/token-guide">Token Cost Guide</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4 class="footer-col-title">Community</h4>
          <ul class="footer-links">
            <li><a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener">GitHub</a></li>
            <li><a href="https://crates.io/crates/lean-ctx" target="_blank" rel="noopener">crates.io</a></li>
            <li><a href="https://discord.gg/pTHkG9Hew9" target="_blank" rel="noopener">Discord</a></li>
            <li><a href="https://buymeacoffee.com/yvgude" target="_blank" rel="noopener">Buy me a Coffee</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <p class="footer-copy">&copy; {year} LeanCTX &middot; MIT License &middot; Made with Rust</p>
      <div class="footer-bottom-links">
