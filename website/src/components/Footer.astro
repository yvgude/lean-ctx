---
const year = new Date().getFullYear();
---

<footer class="relative border-t border-border/50">
  <div class="absolute inset-0 bg-gradient-to-t from-bg via-surface/50 to-transparent pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6 py-16">
    <div class="grid md:grid-cols-4 gap-10 mb-12">
      <div>
        <div class="flex items-center gap-1.5 mb-2">
          <span class="text-lg font-bold text-text-bright">lean</span>
          <span class="text-lg font-light gradient-text-accent">-ctx</span>
        </div>
        <p class="text-xs text-muted/40 mb-4 font-mono">lean context · v1.1.0</p>
        <p class="text-sm text-muted leading-relaxed">
          Smart Context MCP Server.<br />Reduces LLM token consumption by 89–99%.
        </p>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/60 mb-4">Product</h4>
        <ul class="space-y-2.5">
          <li><a href="/features" class="text-sm text-muted hover:text-accent transition-colors duration-300">Features</a></li>
          <li><a href="/features#ctx_read" class="text-sm text-muted hover:text-accent transition-colors duration-300">ctx_read</a></li>
          <li><a href="/features#ctx_analyze" class="text-sm text-muted hover:text-accent transition-colors duration-300">ctx_analyze</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/60 mb-4">Docs</h4>
        <ul class="space-y-2.5">
          <li><a href="/docs/getting-started" class="text-sm text-muted hover:text-accent transition-colors duration-300">Getting Started</a></li>
          <li><a href="/docs/installation" class="text-sm text-muted hover:text-accent transition-colors duration-300">Installation</a></li>
          <li><a href="/docs/tools" class="text-sm text-muted hover:text-accent transition-colors duration-300">Tool Reference</a></li>
          <li><a href="/docs/configuration" class="text-sm text-muted hover:text-accent transition-colors duration-300">Configuration</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted/60 mb-4">Community</h4>
        <ul class="space-y-2.5">
          <li><a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors duration-300">GitHub</a></li>
          <li><a href="https://github.com/yvgude/lean-ctx/issues" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors duration-300">Issues</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border/30 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted/50">&copy; {year} lean-ctx. MIT License.</p>
      <p class="text-xs text-muted/50">Built for developers who care about efficiency.</p>
    </div>
  </div>
</footer>
