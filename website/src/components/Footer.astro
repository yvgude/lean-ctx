          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-root {
    border-top: 1px solid var(--color-border);
  }

  .footer-inner {
    padding-top: clamp(3rem, 2rem + 4vw, 6rem);
    padding-bottom: clamp(1.5rem, 1rem + 1vw, 2.5rem);
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 1.5rem + 2vw, 3rem);
    margin-bottom: clamp(2rem, 1.5rem + 2vw, 3.5rem);
  }
  @media (min-width: 768px) {
    .footer-top {
      grid-template-columns: 1.5fr 3fr;
      gap: clamp(3rem, 2rem + 3vw, 6rem);
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
  }
  .footer-logo-icon {
    width: clamp(1.25rem, 1rem + 0.4vw, 1.5rem);
    height: clamp(1.25rem, 1rem + 0.4vw, 1.5rem);
  }
  .footer-logo-text {
    font-size: clamp(0.9rem, 0.85rem + 0.2vw, 1.1rem);
    font-weight: 700;
  }

  .footer-tagline {
    font-size: clamp(0.8125rem, 0.78rem + 0.1vw, 0.875rem);
    color: var(--color-muted);
    line-height: 1.5;
    max-width: 18rem;
  }

  .footer-columns {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 1rem + 1.5vw, 3rem);
  }
  @media (max-width: 480px) {
    .footer-columns {
      grid-template-columns: 1fr 1fr;
    }
  }

  .footer-col-title {
    font-family: var(--font-display);
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-bright);
    margin-bottom: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(0.375rem, 0.25rem + 0.2vw, 0.5rem);
  }
  .footer-links a {
    font-size: clamp(0.75rem, 0.72rem + 0.1vw, 0.8125rem);
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-links a:hover {
    color: var(--color-text-bright);
  }

  .footer-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);
  }

  .footer-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  @media (min-width: 640px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-copy {
    font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.75rem);
    color: var(--color-muted);
    opacity: 0.7;
  }

  .footer-bottom-links {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .footer-bottom-links a {
    color: var(--color-muted);
    transition: color 0.15s ease;
    opacity: 0.7;
  }
  .footer-bottom-links a:hover {
    color: var(--color-text-bright);
    opacity: 1;
  }
</style>
