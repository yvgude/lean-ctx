---
const year = new Date().getFullYear();
---

<footer class="border-t border-border/50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 sm:gap-10 mb-12">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2 mb-3">
          <svg class="w-6 h-6 shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="32" height="32" rx="7" fill="#0d0d16"/>
            <path d="M6 16L13 9" stroke="#6ee7b7" stroke-width="2.8" stroke-linecap="round"/>
            <path d="M6 16L13 23" stroke="#6ee7b7" stroke-width="2.8" stroke-linecap="round"/>
            <rect x="17" y="10" width="2.2" height="12" rx="1.1" fill="#6ee7b7"/>
            <rect x="22" y="12" width="2.2" height="8" rx="1.1" fill="#6ee7b7" opacity="0.6"/>
            <rect x="27" y="14" width="2.2" height="4" rx="1.1" fill="#6ee7b7" opacity="0.3"/>
          </svg>
          <span class="text-base font-bold"><span class="text-text-bright">Lean</span><span class="text-accent">CTX</span></span>
        </div>
        <p class="text-xs text-muted mb-3 font-mono">MIT · Rust · Open Source</p>
        <p class="text-sm text-muted leading-relaxed mb-5">
          Hybrid Context Optimizer.<br/>
          89–99% fewer tokens for AI coding tools.
        </p>
        <a href="https://buymeacoffee.com/yvgude" target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 px-4 py-2 rounded-lg bg-[#FFDD00]/10 border border-[#FFDD00]/20 text-[#FFDD00] text-xs font-medium hover:bg-[#FFDD00]/20 hover:border-[#FFDD00]/40 transition-all duration-200">
          <svg class="w-4 h-4 shrink-0" viewBox="0 0 884 1279" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
            <path d="m791 298-1-1c-6-11-19-18-33-18H128c-14 0-27 7-33 18l-1 1c-3 6-5 12-5 19v3l85 652c5 40 39 70 79 70h368c40 0 74-30 79-70l85-652v-3c0-7-2-13-5-19z"/>
