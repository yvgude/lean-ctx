          <li><a href="/features" class="text-sm text-muted hover:text-accent transition-colors">Features</a></li>
          <li><a href="/docs/tools" class="text-sm text-muted hover:text-accent transition-colors">ctx_read</a></li>
          <li><a href="/docs/tdd" class="text-sm text-muted hover:text-accent transition-colors">Token Dense Dialect</a></li>
          <li><a href="/docs/dashboard" class="text-sm text-muted hover:text-accent transition-colors">Dashboard</a></li>
          <li><a href="/docs/cli" class="text-sm text-muted hover:text-accent transition-colors">CLI Reference</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-muted mb-4">Docs</h4>
