          <li><a href="https://buymeacoffee.com/yvgude" target="_blank" rel="noopener" class="text-sm text-muted hover:text-[#FFDD00] transition-colors duration-300">Buy me a Coffee</a></li>
        </ul>
      </div>
    </div>

