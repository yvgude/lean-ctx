---
const navItems = [
  { label: 'Features', href: '/features' },
  { label: 'Docs', href: '/docs/getting-started' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 glass-strong">
  <nav class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-1.5 group">
      <span class="text-xl font-bold tracking-tight text-text-bright">lean</span>
      <span class="text-xl font-light gradient-text-accent">-ctx</span>
      <span class="hidden sm:inline text-xs text-muted/40 ml-2 font-normal">lean context</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'text-sm transition-all duration-300',
            currentPath.startsWith(item.href)
              ? 'text-accent font-medium'
              : 'text-muted hover:text-text-bright'
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <span class="hidden lg:inline text-xs font-mono text-muted/30">v1.1.0</span>
      <a
        href="https://github.com/yvgude/lean-ctx"
        target="_blank"
        rel="noopener"
        class="text-muted hover:text-accent transition-colors duration-300"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="/docs/getting-started"
        class="hidden sm:inline-flex items-center px-5 py-2 text-sm font-semibold rounded-lg btn-glossy text-bg"
      >
        Get Started
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden text-muted hover:text-text"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border/50 px-6 py-4">
    {navItems.map(item => (
      <a href={item.href} class="block py-2 text-sm text-muted hover:text-text transition-colors">
        {item.label}
      </a>
    ))}
    <a href="/docs/getting-started" class="block mt-3 text-center py-2 text-sm font-semibold rounded-lg btn-glossy text-bg">
      Get Started
    </a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
