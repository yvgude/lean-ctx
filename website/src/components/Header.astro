---
const navItems = [
  { label: 'Features', href: '/features' },
  { label: 'Docs', href: '/docs/getting-started' },
];

const currentPath = Astro.url.pathname;
const isDocsActive = currentPath.startsWith('/docs');
---

<header class="sticky top-0 z-50 glass-strong">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <svg class="w-7 h-7 shrink-0" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="32" height="32" rx="7" fill="#0d0d16" class="group-hover:fill-[#111120] transition-colors"/>
        <path d="M6 16L13 9" stroke="#6ee7b7" stroke-width="2.8" stroke-linecap="round"/>
        <path d="M6 16L13 23" stroke="#6ee7b7" stroke-width="2.8" stroke-linecap="round"/>
        <rect x="17" y="10" width="2.2" height="12" rx="1.1" fill="#6ee7b7"/>
        <rect x="22" y="12" width="2.2" height="8" rx="1.1" fill="#6ee7b7" opacity="0.6"/>
        <rect x="27" y="14" width="2.2" height="4" rx="1.1" fill="#6ee7b7" opacity="0.3"/>
      </svg>
      <span class="text-xl font-bold tracking-tight text-text-bright">lean</span>
      <span class="text-xl font-light text-accent -ml-1">-ctx</span>
    </a>

    <div class="hidden md:flex items-center gap-8">
      <a
        href="/features"
        class:list={[
          'text-sm transition-all duration-300',
          currentPath === '/features' || currentPath === '/features/'
            ? 'text-accent font-medium'
            : 'text-muted hover:text-text-bright'
        ]}
      >
        Features
      </a>
      <a
        href="/docs/getting-started"
        class:list={[
          'text-sm transition-all duration-300',
          isDocsActive
            ? 'text-accent font-medium'
            : 'text-muted hover:text-text-bright'
        ]}
      >
        Docs
      </a>
    </div>

    <div class="flex items-center gap-3 sm:gap-4">
      <span class="hidden lg:inline text-xs font-mono text-muted/30">v1.4.0</span>
      <a
        href="https://buymeacoffee.com/yvgude"
        target="_blank"
        rel="noopener"
        class="hidden sm:inline-flex items-center gap-1.5 text-xs text-muted hover:text-[#FFDD00] transition-colors duration-300"
        aria-label="Buy me a coffee"
      >
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.216 6.415l-.132-.666c-.119-.598-.388-1.163-1.001-1.379-.197-.069-.42-.098-.57-.241-.152-.143-.196-.366-.231-.572-.065-.378-.125-.756-.192-1.133-.057-.325-.102-.69-.25-.987-.195-.4-.597-.634-.996-.788a5.723 5.723 0 00-.626-.194c-1-.263-2.05-.36-3.077-.416a25.834 25.834 0 00-3.7.062c-.915.083-1.88.184-2.75.5-.318.116-.646.256-.888.501-.297.302-.393.77-.177 1.146.154.267.415.456.692.58.36.162.737.284 1.123.366 1.075.238 2.189.331 3.287.37 1.218.05 2.437.01 3.65-.118.299-.033.598-.073.896-.119.352-.054.578-.513.474-.834-.124-.383-.457-.531-.834-.473-.466.074-.96.108-1.382.146-1.177.08-2.358.082-3.536.006a22.228 22.228 0 01-1.157-.107c.505-.024.853-.087 1.35-.156.734-.102 1.471-.19 2.209-.28.53-.064 1.074-.098 1.6-.182.488-.078.953-.217 1.405-.422.457-.208.757-.537.905-.996.034-.114.054-.232.074-.35l.088-.455c.025-.132.05-.264.073-.396zM9.333 12.64l.007.009c-.003-.003-.007-.006-.007-.009zm9.34-4.025c-.024.073-.065.144-.08.22-.023.121-.015.247-.016.371-.003.327-.015.654-.04.98-.024.32-.058.637-.105.953-.085.565-.202 1.124-.354 1.675-.118.426-.256.844-.412 1.256-.068.179-.139.357-.227.527-.14.27-.336.396-.642.389-.36-.009-.72-.019-1.079-.035a48.395 48.395 0 01-3.614-.249c-1.033-.104-2.061-.234-3.082-.405l-.138-.025c.003.009.007.013.013.022l-.01-.018a.74.74 0 00-.045-.083c-.204-.335-.502-.59-.861-.716-.354-.124-.74-.125-1.109-.064-.316.053-.582.192-.82.36a5.87 5.87 0 00-.32.263c-.071.062-.16.118-.189.209-.037.112.015.239.094.329.207.235.534.339.836.32a.75.75 0 00.265-.073c.102-.052.197-.122.31-.148.175-.04.355-.012.53.027.25.056.495.137.73.236.476.203.917.466 1.324.775.148.112.286.242.45.33.323.175.73.162 1.081.064.293-.082.555-.234.8-.402.362-.249.688-.537.984-.856.304-.327.564-.692.756-1.094.074-.156.137-.317.184-.483.134.148.261.303.384.46.483.613.897 1.278 1.214 1.987a16.55 16.55 0 01.727 2.055c.068.244.124.491.159.743.005.037.008.075.01.112l.012.152c.001.048-.003.097.01.143a.38.38 0 00.105.19c.053.05.121.074.188.083a.596.596 0 00.184-.003c.068-.0