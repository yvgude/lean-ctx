---
import MegaDropdown from './MegaDropdown.astro';
import SearchModal from './SearchModal.astro';

const currentPath = Astro.url.pathname;

const productColumns = [
  {
    title: 'Compression Layers',
    items: [
      {
        label: 'Context Server',
        href: '/mcp-server',
        description: '24 intelligent compression tools',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><circle cx="6" cy="6" r="1"/><circle cx="6" cy="18" r="1"/></svg>',
      },
      {
        label: 'Shell Hook',
        href: '/shell-hook',
        description: '90+ command patterns, zero config',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>',
      },
      {
        label: 'Protocols',
        href: '/protocols',
        description: 'CEP, CCP & TDD communication',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>',
      },
    ],
  },
  {
    title: 'Protocols',
    items: [
      {
        label: 'CEP',
        href: '/protocols/cep',
        description: 'Cognitive Efficiency Protocol',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>',
      },
      {
        label: 'CCP',
        href: '/protocols/ccp',
        description: 'Context Continuity Protocol',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>',
      },
      {
        label: 'TDD',
        href: '/protocols/tdd',
        description: 'Token Dense Dialect',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>',
      },
    ],
  },
  {
    title: 'Developer',
    items: [
      {
        label: 'CLI Reference',
        href: '/cli',
        description: 'Terminal commands for humans',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 8l4 4-4 4"/><line x1="13" y1="16" x2="17" y2="16"/></svg>',
      },
      {
        label: 'Compatibility',
        href: '/compatibility',
        description: 'Every supported AI tool',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>',
      },
      {
        label: 'Benchmark',
        href: '/benchmark',
        description: 'Verify savings in your codebase',
        icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>',
      },
    ],
  },
];

const docsColumns = [
  {
    title: 'Get Started',
    items: [
      { label: 'Installation & Setup', href: '/docs/getting-started', description: 'Ready in 60 seconds', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>' },
      { label: 'Configuration', href: '/docs/configuration', description: 'config.toml & environment', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/></svg>' },
      { label: 'Quick Reference', href: '/docs/quick-reference', description: 'Daily workflow cheat sheet', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>' },
    ],
  },
  {
    title: 'Reference',
    items: [
      { label: 'CLI Reference (Complete)', href: '/docs/cli-reference', description: 'Every command, flag, and mode', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 8l4 4-4 4"/><line x1="13" y1="16" x2="17" y2="16"/></svg>' },
      { label: 'Analytics & Dashboards', href: '/docs/analytics', description: 'Gain, Wrapped, Dashboard guide', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>' },
      { label: 'Tool API Reference', href: '/docs/tools', description: 'All 24 intelligent tools documented', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>' },
      { label: 'Tree-sitter Engine', href: '/docs/tree-sitter', description: 'AST parsing for 14 languages', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/></svg>' },
      { label: 'Token Cost Guide', href: '/docs/token-guide', description: 'Optimization strategies', icon: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>' },
    ],
  },
];
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-accent focus:text-bg focus:text-sm">
  Skip to content
</a>

<header id="site-header" class="header-root" data-scrolled="false">
  <nav class="content-grid-wide">
    <div class="header-inner">
      <a href="/" class="header-logo">
        <svg class="header-logo-icon" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect width="32" height="32" rx="7" fill="#0a0a12"/>
          <path d="M6 16L13 9" stroke="#34d399" stroke-width="2.8" stroke-linecap="round"/>
          <path d="M6 16L13 23" stroke="#34d399" stroke-width="2.8" stroke-linecap="round"/>
          <rect x="17" y="10" width="2.2" height="12" rx="1.1" fill="#34d399"/>
          <rect x="22" y="12" width="2.2" height="8" rx="1.1" fill="#34d399" opacity="0.6"/>
          <rect x="27" y="14" width="2.2" height="4" rx="1.1" fill="#34d399" opacity="0.3"/>
        </svg>
        <span class="header-logo-text font-display">
          <span class="text-text-bright">Lean</span><span class="text-accent">CTX</span>
        </span>
      </a>

      <div class="header-center">
        <a href="/how-it-works" class:list={['header-nav-item', currentPath.startsWith('/how-it-works') ? 'is-active' : '']}>
          How It Works
        </a>
        <MegaDropdown id="product" label="Product" columns={productColumns} />
        <MegaDropdown id="docs" label="Docs" columns={docsColumns} />
        <!-- Pro nav link hidden until launch -->
        <!--<a href="/pro" class:list={['header-nav-item header-nav-pro', currentPath.startsWith('/pro') ? 'is-active' : '']}>
          Pro
        </a>-->
      </div>

      <div class="header-right">
        <button data-search-trigger class="header-search-btn" aria-label="Search documentation (⌘K)">
          <svg class="w-[16px] h-[16px]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span class="header-search-label">Search</span>
          <kbd class="header-search-kbd">⌘K</kbd>
        </button>

        <a href="https://discord.gg/pTHkG9Hew9" target="_blank" rel="noopener" class="header-discord" aria-label="Discord">
          <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        </a>

        <a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="header-github-cta">
          <svg class="header-gh-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          <span class="header-gh-label">Star</span>
          <span class="header-gh-divider"></span>
          <span id="gh-stars" class="header-gh-count">—</span>
        </a>

        <a href="/docs/getting-started" class="header-cta">
          Get Started
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>

        <button id="mobile-menu-btn" class="header-mobile-btn" aria-label="Menu">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu-closed">
    <div class="mobile-menu-inner">
      <a href="/how-it-works" class="mobile-nav-link">How It Works</a>

      <div class="mobile-section">
        <span class="mobile-section-title">Product</span>
        <a href="/mcp-server" class="mobile-nav-link">Context Server</a>
        <a href="/shell-hook" class="mobile-nav-link">Shell Hook</a>
        <a href="/protocols" class="mobile-nav-link">Protocols</a>
        <a href="/cli" class="mobile-nav-link">CLI Reference</a>
        <a href="/compatibility" class="mobile-nav-link">Compatibility</a>
        <a href="/benchmark" class="mobile-nav-link">Benchmark</a>
      </div>

      <div class="mobile-section">
        <span class="mobile-section-title">Documentation</span>
        <a href="/docs/getting-started" class="mobile-nav-link">Installation & Setup</a>
        <a href="/docs/configuration" class="mobile-nav-link">Configuration</a>
        <a href="/docs/cli-reference" class="mobile-nav-link">CLI Reference (Complete)</a>
        <a href="/docs/analytics" class="mobile-nav-link">Analytics & Dashboards</a>
        <a href="/docs/tools" class="mobile-nav-link">Tool API Reference</a>
        <a href="/docs/quick-reference" class="mobile-nav-link">Quick Reference</a>
      </div>

      <div class="mobile-cta-area">
        <a href="/docs/getting-started" class="mobile-get-started">
          Get Started
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</header>

<SearchModal />

<style>
  .header-root {
    position: sticky;
    top: 0;
    z-index: 50;
    background: transparent;
    transition: background 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }
  .header-root[data-scrolled="true"] {
    background: rgba(5, 5, 7, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom-color: var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: clamp(3.5rem, 3rem + 2vw, 4.5rem);
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    text-decoration: none;
    flex-shrink: 0;
  }
  .header-logo-icon {
    width: clamp(1.5rem, 1.25rem + 0.5vw, 1.875rem);
    height: clamp(1.5rem, 1.25rem + 0.5vw, 1.875rem);
  }
  .header-logo-text {
    font-size: clamp(1rem, 0.9rem + 0.3vw, 1.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .header-center {
    display: none;
    align-items: center;
    gap: 0;
  }
  @media (min-width: 768px) {
    .header-center { display: flex; }
  }

  /* All nav items share the same style */
  .header-nav-item,
  :global(.mega-dd-trigger) {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px clamp(10px, 0.6rem + 0.4vw, 14px);
    font-size: clamp(0.8125rem, 0.78rem + 0.12vw, 0.875rem);
    font-weight: 450;
    color: var(--color-muted);
    transition: color 0.2s ease;
    text-decoration: none;
    white-space: nowrap;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    line-height: 1;
  }
  .header-nav-item:hover,
  :global(.mega-dd-trigger:hover) {
    color: var(--color-text-bright);
  }
  .header-nav-item.is-active {
    color: var(--color-text-bright);
  }
  .header-nav-pro {
    color: var(--color-accent) !important;
    font-weight: 600;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: clamp(0.5rem, 0.3rem + 0.4vw, 0.75rem);
  }

  .header-search-btn {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 0.625rem;
    font-size: 0.8125rem;
    font-weight: 400;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    background: transparent;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease;
    white-space: nowrap;
    font-family: inherit;
    line-height: 1;
  }
  .header-search-btn:hover {
    border-color: var(--color-muted);
    color: var(--color-text-bright);
  }
  .header-search-label {
    font-size: 0.8125rem;
  }
  .header-search-kbd {
    font-size: 0.625rem;
    font-family: inherit;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-muted);
    margin-left: 0.25rem;
    line-height: 1;
  }
  @media (min-width: 640px) {
    .header-search-btn { display: inline-flex; }
  }

  .header-discord {
    display: none;
    align-items: center;
    padding: 0.375rem;
    border-radius: 6px;
    color: var(--color-muted);
    transition: color 0.2s ease;
  }
  .header-discord:hover {
    color: #5865F2;
  }
  @media (min-width: 640px) {
    .header-discord { display: flex; }
  }

  .header-github-cta {
    display: none;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.875rem;
    font-size: 0.8125rem;
    font-weight: 500;
    border-radius: 8px;
    border: 1px solid var(--color-border-light);
    color: var(--color-text-bright);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease;
    white-space: nowrap;
    line-height: 1;
  }
  .header-github-cta:hover {
    border-color: var(--color-muted);
    background: rgba(255, 255, 255, 0.03);
  }
  .header-gh-icon {
    width: 16px;
    height: 16px;
  }
  .header-gh-label {
    font-weight: 600;
  }
  .header-gh-divider {
    width: 1px;
    height: 14px;
    background: var(--color-border-light);
  }
  .header-gh-count {
    font-variant-numeric: tabular-nums;
    color: var(--color-muted);
    font-size: 0.75rem;
  }
  @media (min-width: 640px) {
    .header-github-cta { display: inline-flex; }
  }

  .header-cta {
    display: none;
    align-items: center;
    gap: 0.375rem;
    padding: 0.4rem 1rem;
    font-size: 0.8125rem;
    font-weight: 600;
    border-radius: 8px;
    background: var(--color-accent);
    color: var(--color-bg);
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }
  .header-cta:hover {
    opacity: 0.88;
  }
  @media (min-width: 640px) {
    .header-cta { display: inline-flex; }
  }

  .header-mobile-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-muted);
    padding: 0.375rem;
    border: none;
    background: none;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .header-mobile-btn:hover {
    color: var(--color-text-bright);
  }
  @media (min-width: 768px) {
    .header-mobile-btn { display: none; }
  }

  .mobile-menu-closed { display: none; }
  .mobile-menu-open {
    display: block;
    background: rgba(5, 5, 7, 0.98);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-top: 1px solid var(--color-border);
    animation: menuReveal 0.25s ease;
  }
  @keyframes menuReveal {
    from { opacity: 0; transform: translateY(-6px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @media (min-width: 768px) {
    .mobile-menu-open { display: none; }
  }

  .mobile-menu-inner {
    padding: clamp(1rem, 0.75rem + 1vw, 1.5rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    max-height: calc(100dvh - 4rem);
    overflow-y: auto;
  }

  .mobile-section {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .mobile-section-title {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    padding: 0 0.75rem;
    margin-bottom: 0.25rem;
    opacity: 0.5;
  }

  .mobile-nav-link {
    display: block;
    padding: 0.625rem 0.75rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    border-radius: 8px;
    transition: color 0.2s ease;
    text-decoration: none;
  }
  .mobile-nav-link:hover {
    color: var(--color-text-bright);
  }

  .mobile-cta-area {
    padding-top: 0.5rem;
  }
  .mobile-get-started {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    padding: 0.75rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    background: var(--color-accent);
    color: var(--color-bg);
    text-decoration: none;
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    if (menu?.classList.contains('mobile-menu-closed')) {
      menu.classList.remove('mobile-menu-closed');
      menu.classList.add('mobile-menu-open');
    } else {
      menu?.classList.remove('mobile-menu-open');
      menu?.classList.add('mobile-menu-closed');
    }
  });

  const header = document.getElementById('site-header');
  if (header) {
    const update = () => {
      header.dataset.scrolled = window.scrollY > 20 ? 'true' : 'false';
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }

  document.querySelectorAll<HTMLDivElement>('.mega-dd-wrapper').forEach(wrapper => {
    const trigger = wrapper.querySelector('.mega-dd-trigger');
    let closeTimer: ReturnType<typeof setTimeout>;

    function open() {
      clearTimeout(closeTimer);
      document.querySelectorAll('.mega-dd-wrapper.is-open').forEach(w => {
        if (w !== wrapper) w.classList.remove('is-open');
      });
      wrapper.classList.add('is-open');
      trigger?.setAttribute('aria-expanded', 'true');
    }

    function close() {
      closeTimer = setTimeout(() => {
        wrapper.classList.remove('is-open');
        trigger?.setAttribute('aria-expanded', 'false');
      }, 180);
    }

    wrapper.addEventListener('mouseenter', open);
    wrapper.addEventListener('mouseleave', close);

    trigger?.addEventListener('click', (e) => {
      e.preventDefault();
      wrapper.classList.contains('is-open') ? close() : open();
    });

    trigger?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') {
        wrapper.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      }
    });

    const panel = wrapper.querySelector('.mega-dd-panel');
    panel?.addEventListener('mouseenter', () => clearTimeout(closeTimer));
    panel?.addEventListener('mouseleave', close);
  });

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.mega-dd-wrapper')) {
      document.querySelectorAll('.mega-dd-wrapper.is-open').forEach(w => {
        w.classList.remove('is-open');
        w.querySelector('.mega-dd-trigger')?.setAttribute('aria-expanded', 'false');
      });
    }
  });

  fetch('https://api.github.com/repos/yvgude/lean-ctx')
    .then(r => r.json())
    .then(data => {
      const el = document.getElementById('gh-stars');
      if (el && data.stargazers_count != null) {
        const count = data.stargazers_count;
        el.textContent = count >= 1000 ? (count / 1000).toFixed(1) + 'k' : String(count);
      }
    })
    .catch(() => {});
</script>
