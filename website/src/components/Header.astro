        </svg>
        Support
      </a>
      <a
        href="https://discord.gg/pTHkG9Hew9"
        target="_blank"
        rel="noopener"
        class="text-muted hover:text-[#5865F2] transition-colors duration-300"
        aria-label="Discord"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/>
        </svg>
      </a>
      <a
        href="https://github.com/yvgude/lean-ctx"
        target="_blank"
        rel="noopener"
        class="text-muted hover:text-accent transition-colors duration-300"
        aria-label="GitHub"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
      <a
        href="/docs/getting-started"
        class="hidden sm:inline-flex items-center px-5 py-2 text-sm font-semibold rounded-lg btn-glossy text-bg"
      >
        Get Started
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="md:hidden text-muted hover:text-text"
      aria-label="Menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border/50 px-4 py-4 space-y-1">
    <a href="/features" class="block py-2.5 px-3 text-sm text-muted hover:text-accent hover:bg-surface-2 rounded-lg transition-all">Features</a>
    <a href="/docs/getting-started" class="block py-2.5 px-3 text-sm text-muted hover:text-accent hover:bg-surface-2 rounded-lg transition-all">Getting Started</a>
    <a href="/docs/installation" class="block py-2.5 px-3 text-sm text-muted hover:text-accent hover:bg-surface-2 rounded-lg transition-all">Installation</a>
    <a href="/docs/tdd" class="block py-2.5 px-3 text-sm text-muted hover:text-accent hover:bg-surface-2 rounded-lg transition-all">Token Dense Dialect</a>
    <a href="/docs/cli" class="block py-2.5 px-3 text-sm text-muted hover:text-accent hover:bg-surface-2 rounded-lg transition-all">CLI Reference</a>
    <div class="pt-3 flex flex-col gap-2">
      <a href="https://discord.gg/pTHkG9Hew9" target="_blank" rel="noopener" class="block text-center py-2.5 text-sm font-medium rounded-lg border border-[#5865F2]/30 bg-[#5865F2]/10 text-[#5865F2]">Discord</a>
      <a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="block text-center py-2.5 text-sm font-medium rounded-lg btn-outline-glossy text-accent">GitHub</a>
      <a href="/docs/getting-started" class="block text-center py-2.5 text-sm font-semibold rounded-lg btn-glossy text-bg">Get Started</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
