    </div>

    <button id="mobile-menu-btn" class="md:hidden text-muted hover:text-text p-1" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden md:hidden border-t border-border/50 px-4 py-4 space-y-1">
