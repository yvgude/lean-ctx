<style>
  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(52, 211, 153, 0.06), transparent 60%);
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-fade {
    opacity: 0;
    transform: translateY(20px);
    animation: heroFadeIn 0.7s ease-out forwards;
  }
  .hero-fade:nth-child(1) { animation-delay: 0.1s; }
  .hero-fade:nth-child(2) { animation-delay: 0.2s; }
  .hero-fade:nth-child(3) { animation-delay: 0.35s; }
  .hero-fade:nth-child(4) { animation-delay: 0.5s; }
  .hero-fade:nth-child(5) { animation-delay: 0.6s; }
  .hero-fade:nth-child(6) { animation-delay: 0.7s; }

  @keyframes heroFadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .term-anim > p {
    opacity: 0;
    transform: translateY(8px);
  }
  .term-anim.is-visible > p {
    animation: termFadeIn 0.35s ease-out forwards;
  }
  .term-anim.is-visible > .term-cmd::after {
    content: '▋';
    animation: cursorBlink 0.8s step-end 3;
    color: var(--color-accent);
    margin-left: 2px;
  }
  .term-anim .term-bar {
    display: inline-block;
    clip-path: inset(0 100% 0 0);
  }
  .term-anim.is-visible .term-bar {
    animation: barGrow 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes termFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes barGrow {
    from { clip-path: inset(0 100% 0 0); }
    to { clip-path: inset(0 0 0 0); }
  }
  @keyframes cursorBlink {
    50% { opacity: 0; }
  }

  .protocol-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.25s ease;
    position: relative;
  }
  .protocol-badge:hover {
    border-color: var(--color-accent);
    background: rgba(52, 211, 153, 0.06);
    color: var(--color-text-bright);
  }
  .protocol-badge::after {
    content: attr(data-tooltip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 6px 10px;
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.4;
    color: var(--color-text);
    background: var(--color-surface-3);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 10;
  }
  .protocol-badge:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .protocol-badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 1.25rem;
    padding: 10px 16px;
    background: var(--color-surface);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    width: fit-content;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 14px;
    position: relative;
    cursor: default;
  }

  .hero-stat-value {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .hero-stat-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 2px;
  }

  .hero-stat[data-info]::after {
    content: attr(data-info);
    position: absolute;
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(4px);
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--color-text);
    background: var(--color-surface-3);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    white-space: normal;
    width: max-content;
    max-width: 240px;
    text-align: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 20;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  .hero-stat[data-info]:hover::after {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .hero-stat-divider {
    width: 1px;
    height: 28px;
    background: rgba(255, 255, 255, 0.08);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .hero-stats {
      padding: 8px 10px;
      gap: 0;
      width: 100%;
      justify-content: space-between;
    }
    .hero-stat {
      padding: 0 8px;
    }
    .hero-stat-value {
      font-size: 14px;
    }
    .hero-stat-label {
      font-size: 7px;
    }
    .hero-stat[data-info]::after {
      display: none;
    }
    .hero-stat-divider {
      height: 24px;
    }
    .protocol-badge::after {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fade { opacity: 1; transform: none; animation: none; }
    .term-anim > p { opacity: 1; transform: none; }
    .term-anim .term-bar { clip-path: none; }
  }
</style>

<script>
  function animateTerminal(el: HTMLElement | null) {
    if (!el || el.classList.contains('is-visible')) return;
    const lines = el.querySelectorAll(':scope > p');
    lines.forEach((line, i) => {
      (line as HTMLElement).style.animationDelay = `${i * 80}ms`;
      const bar = line.querySelector('.term-bar');
      if (bar) (bar as HTMLElement).style.animationDelay = `${i * 80 + 200}ms`;
    });
    el.classList.add('is-visible');
  }

  document.addEventListener('DOMContentLoaded', () => {
    setTimeout(() => animateTerminal(document.getElementById('hero-terminal')), 600);
    setTimeout(() => animateTerminal(document.getElementById('hero-terminal-mobile')), 600);
  });
</script>
