---
const problems = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>`,
    title: 'Redundant context',
    stat: '~65%',
    description: 'of file reads in a coding session are re-reads. Your AI agent receives the same content over and over, wasting tokens on context it already has.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/>`,
    title: 'Token budget burns fast',
    stat: '$20–200',
    description: 'per month — and every AI tool has hard limits. 500 requests, 45 messages per 5 hours, limited credits. Once you hit the cap, you wait.',
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>`,
    title: 'Worse reasoning',
    stat: '200K',
    description: 'token context windows fill up with noise. The more irrelevant tokens the model processes, the lower the quality of its reasoning and code output.',
  },
];
---

<section class="relative py-24 overflow-hidden">
  <div class="relative max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-3">The problem</p>
      <h2 class="text-3xl sm:text-4xl font-bold mb-5">AI coding tools were not built to be <span class="text-accent">token-efficient</span></h2>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Every file read, every CLI output, every project scan — sent in full, every time. The cost adds up fast.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-5">
      {problems.map(p => (
        <div class="card-premium rounded-2xl p-7">
          <div class="w-11 h-11 rounded-xl bg-surface-3 border border-border-light/50 flex items-center justify-center mb-5">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <Fragment set:html={p.icon} />
            </svg>
          </div>
          <p class="text-3xl font-extrabold text-accent mb-2">{p.stat}</p>
          <h3 class="text-lg font-bold text-text-bright mb-3">{p.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{p.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
