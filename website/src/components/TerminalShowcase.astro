<style>
  .term-tab {
    color: var(--color-muted);
    border-bottom: 2px solid transparent;
  }
  .term-tab:hover { color: var(--color-text); }
  .term-tab.active {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
</style>

<script>
  document.querySelectorAll('.term-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-tab');
      const container = tab.closest('section');
      if (!container || !target) return;

      container.querySelectorAll('.term-tab').forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      container.querySelectorAll('.term-panel').forEach(p => {
        const el = p as HTMLElement;
        el.style.display = el.getAttribute('data-panel') === target ? 'block' : 'none';
        el.classList.toggle('active', el.getAttribute('data-panel') === target);
      });
    });
  });
</script>
