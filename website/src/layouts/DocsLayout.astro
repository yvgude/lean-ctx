---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={`${title} — lean-ctx Docs`} description={description}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-8 sm:py-16 lg:grid lg:grid-cols-[240px_1fr] lg:gap-12">
    <DocsSidebar />
    <article class="min-w-0 prose prose-invert max-w-none
      [&_h1]:text-2xl [&_h1]:sm:text-3xl [&_h1]:font-bold [&_h1]:mb-6 [&_h1]:text-text-bright
      [&_h2]:text-lg [&_h2]:sm:text-xl [&_h2]:font-semibold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-text-bright
      [&_h3]:text-base [&_h3]:sm:text-lg [&_h3]:font-medium [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-text-bright
      [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4 [&_p]:text-sm [&_p]:sm:text-base
      [&_a]:text-accent [&_a]:underline [&_a]:underline-offset-2
      [&_code]:bg-surface-2 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-md [&_code]:text-accent-2 [&_code]:text-xs [&_code]:sm:text-sm [&_code]:border [&_code]:border-border/30
      [&_pre]:bg-surface [&_pre]:border [&_pre]:border-border/30 [&_pre]:rounded-xl [&_pre]:p-3 [&_pre]:sm:p-5 [&_pre]:overflow-x-auto [&_pre]:mb-6 [&_pre]:text-xs [&_pre]:sm:text-sm
      [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:border-0
      [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:sm:pl-6 [&_ul]:mb-4 [&_ul]:text-muted [&_ul]:text-sm [&_ul]:sm:text-base
      [&_ol]:list-decimal [&_ol]:pl-5 [&_ol]:sm:pl-6 [&_ol]:mb-4 [&_ol]:text-muted [&_ol]:text-sm [&_ol]:sm:text-base
      [&_li]:mb-1
      [&_table]:w-full [&_table]:mb-6 [&_table]:text-xs [&_table]:sm:text-sm
      [&_th]:text-left [&_th]:text-xs [&_th]:uppercase [&_th]:tracking-wider [&_th]:text-muted/60 [&_th]:pb-3 [&_th]:border-b [&_th]:border-border/30 [&_th]:px-2
      [&_td]:py-2.5 [&_td]:text-sm [&_td]:border-b [&_td]:border-border/20 [&_td]:px-2
      [&_blockquote]:border-l-2 [&_blockquote]:border-accent/40 [&_blockquote]:pl-4 [&_blockquote]:text-muted [&_blockquote]:italic
      [&_strong]:text-text-bright [&_strong]:font-semibold
      ">
      <h1>{title}</h1>
      <slot />
    </article>
  </div>
</BaseLayout>
