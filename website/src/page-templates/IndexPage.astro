<script is:inline>
(function() {
  var installEl = document.getElementById('install-count');
  var starsEl = document.getElementById('github-stars-hero');
  var installs = 0;
  var installsDone = 0;
  var installsTotal = 4;

  function countUp(el, target, duration) {
    var start = 0;
    var startTime = null;
    function step(ts) {
      if (!startTime) startTime = ts;
      var progress = Math.min((ts - startTime) / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = Math.floor(ease * target);
      el.textContent = current.toLocaleString('en-US');
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function updateInstalls() {
    installsDone++;
    if (installsDone >= installsTotal && installs > 0 && installEl) {
      countUp(installEl, installs, 1200);
    }
  }

  fetch('https://crates.io/api/v1/crates/lean-ctx')
    .then(function(r) { return r.json(); })
    .then(function(d) { installs += d.crate.downloads || 0; updateInstalls(); })
    .catch(updateInstalls);

  fetch('https://api.npmjs.org/downloads/point/2000-01-01:2099-01-01/lean-ctx-bin')
    .then(function(r) { return r.json(); })
    .then(function(d) { installs += d.downloads || 0; updateInstalls(); })
    .catch(updateInstalls);

  fetch('https://api.npmjs.org/downloads/point/2000-01-01:2099-01-01/pi-lean-ctx')
    .then(function(r) { return r.json(); })
    .then(function(d) { installs += d.downloads || 0; updateInstalls(); })
    .catch(updateInstalls);

  function fetchAllGitHubDownloads(page, acc) {
    fetch('https://api.github.com/repos/yvgude/lean-ctx/releases?per_page=100&page=' + page)
      .then(function(r) { return r.json(); })
      .then(function(releases) {
        if (Array.isArray(releases) && releases.length > 0) {
          for (var i = 0; i < releases.length; i++) {
            var assets = releases[i].assets || [];
            for (var j = 0; j < assets.length; j++) {
              acc.total += assets[j].download_count || 0;
            }
          }
          if (releases.length === 100) {
            fetchAllGitHubDownloads(page + 1, acc);
            return;
          }
        }
        installs += acc.total;
        updateInstalls();
      })
      .catch(updateInstalls);
  }
  fetchAllGitHubDownloads(1, { total: 0 });

  if (starsEl) {
    fetch('https://api.github.com/repos/yvgude/lean-ctx')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.stargazers_count) countUp(starsEl, d.stargazers_count, 1000);
      })
      .catch(function() {});
  }
})();
</script>

