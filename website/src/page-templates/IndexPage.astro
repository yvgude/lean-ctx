  .group:hover .layer-link {
    gap: 0.625rem;
  }

  /* ── Terminal Visualizations ──────────────────────────── */
  .term-divider {
    height: 1px;
    background: var(--color-border);
  }
  .metrics-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ── Ecosystem: Layout ──────────────────────────── */
  .eco-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.5rem, 1rem + 1vw, 2rem);
