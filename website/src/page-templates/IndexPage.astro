  }
  @media (min-width: 480px) {
    .eco-tui { font-size: 12.5px; line-height: 1.6; border-radius: 16px; }
  }
  .eco-tui:hover {
    box-shadow:
      0 0 0 1px rgba(34,197,94,.08),
      0 16px 48px rgba(0,0,0,.8),
      0 0 100px -20px rgba(34,197,94,.18);
    transform: translateY(-4px);
  }
  .eco-tui-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 8px 10px;
    background: #2D2C35;
    border-bottom: 1px solid rgba(58,57,67,.5);
