---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title={t('index.title')}>

<!-- ═══════════════════════════════════════════════════════
     HERO
     ═══════════════════════════════════════════════════════ -->
<section class="section-hero">
  <div class="content-grid">
    <div class="animate-entrance">
      <p class="fluid-label text-accent" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2.5rem);">
        {t('index.heroLabel')}
      </p>
    </div>

    <h1 class="font-display fluid-display font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2rem);">
      {t('index.heroTitle')}<br/>
      <span class="gradient-text">{t('index.heroTitleHighlight')}</span>
    </h1>

    <div class="hero-proof animate-entrance stagger-2" style="margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 2.5rem);">
      <div class="hero-proof-item">
        <span class="hero-proof-number font-display" id="install-count">—</span>
        <span class="hero-proof-label">{t('index.heroProofInstalls')}</span>
      </div>
      <div class="hero-proof-divider"></div>
      <div class="hero-proof-item">
        <span class="hero-proof-number font-display" id="github-stars-hero">—</span>
        <span class="hero-proof-label">{t('index.heroProofStars')}</span>
      </div>
      <div class="hero-proof-divider"></div>
      <div class="hero-proof-item">
        <span class="hero-proof-number font-display">18</span>
        <span class="hero-proof-label">{t('index.heroProofLanguages')}</span>
      </div>
      <div class="hero-proof-divider"></div>
      <div class="hero-proof-item">
        <span class="hero-proof-number font-display">23</span>
        <span class="hero-proof-label">{t('index.heroProofTools')}</span>
      </div>
    </div>

    <p class="fluid-body text-muted animate-entrance stagger-3" style="margin-bottom: clamp(2rem, 1.5rem + 1.5vw, 3.5rem); max-width: 44rem;">
      {t('index.heroDescription')}
    </p>

    <div class="flex flex-wrap items-center animate-entrance stagger-4" style="gap: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);">
      <a href={lp('/docs/getting-started')} class="btn-primary inline-flex items-center gap-2 rounded-lg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('nav.getStarted')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="btn-outline inline-flex items-center gap-2 rounded-lg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
        {t('index.starOnGithub')}
      </a>
      <a href="https://discord.gg/pTHkG9Hew9" target="_blank" rel="noopener" class="inline-flex items-center gap-2 text-muted hover:text-text-bright transition-colors" style="font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem); font-weight: 500;">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
        {t('index.joinDiscord')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════════════════════════════════════════════════════
     WHAT HAPPENS (replaces confusing numbers section)
     ═══════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('index.problemLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.25rem, 1rem + 0.5vw, 2rem);">
      {t('index.problemTitle')}
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem); max-width: 48rem;">
      {t('index.problemDesc')}
    </p>
    <p class="fluid-body text-text-bright font-medium animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem; font-style: italic;">
      {t('index.problemQuote')}
    </p>

    <div class="grid md:grid-cols-2 animate-entrance stagger-3" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">
      <!-- Without -->
      <div class="compare-card">
        <div class="compare-header compare-header--bad">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
          {t('index.withoutLeanCtx')}
        </div>
        <div class="compare-body font-mono" style="font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem);">
          <div class="compare-line"><span class="text-muted">{t('index.without1')}</span></div>
          <div class="compare-line"><span class="text-danger">{t('index.without2')}</span></div>
          <div class="compare-line"><span class="text-muted">{t('index.without3')}</span></div>
          <div class="compare-line"><span class="text-danger">{t('index.without4')}</span></div>
        </div>
      </div>
      <!-- With -->
      <div class="compare-card">
        <div class="compare-header compare-header--good">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          {t('index.withLeanCtx')}
        </div>
        <div class="compare-body font-mono" style="font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem);">
          <div class="compare-line"><span class="text-muted">{t('index.with1')}</span></div>
          <div class="compare-line"><span class="text-accent">{t('index.with2')}</span></div>
          <div class="compare-line"><span class="text-muted">{t('index.with3')}</span></div>
          <div class="compare-line"><span class="text-accent">{t('index.with4')}</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════════════════════════════════════════════════════
     LIVE PREVIEW: Terminal + Dashboard
     ═══════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('index.previewLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.25rem, 1rem + 0.5vw, 2rem);">
      {t('index.previewTitle')}
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 5rem); max-width: 48rem;">
      {t('index.previewDesc')}
    </p>

    <div class="grid lg:grid-cols-2 animate-entrance stagger-3" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">
      <!-- Terminal: ctx_read in action -->
      <div class="terminal-chrome">
        <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
          <span class="terminal-dot bg-[#ff5f57]"></span>
          <span class="terminal-dot bg-[#febc2e]"></span>
          <span class="terminal-dot bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-muted font-mono">ctx_read — map mode</span>
        </div>
        <div class="terminal-body px-5 py-5 font-mono space-y-3" style="font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem); line-height: 1.7;">
          <div>
            <span class="text-accent-2">AI calls:</span> <span class="text-text-bright">ctx_read("src/auth/service.ts", mode="map")</span>
          </div>
          <div class="term-divider"></div>
          <div>
            <span class="text-muted">F7=service.ts 342L</span>
          </div>
          <div>
            <span class="text-accent">§ AuthService</span>
          </div>
          <div class="pl-4">
            <span class="text-muted">deps:</span> <span class="text-text">jwt, bcrypt, prisma</span>
          </div>
          <div class="pl-4">
            <span class="text-muted">exports:</span>
          </div>
          <div class="pl-8">
            <span class="text-accent-2-bright">λ</span> <span class="text-text-bright">login</span><span class="text-muted">(email: string, pwd: string) → Promise&lt;Token&gt;</span>
          </div>
          <div class="pl-8">
            <span class="text-accent-2-bright">λ</span> <span class="text-text-bright">register</span><span class="text-muted">(data: CreateUser) → Promise&lt;User&gt;</span>
          </div>
          <div class="pl-8">
            <span class="text-accent-2-bright">λ</span> <span class="text-text-bright">verify</span><span class="text-muted">(token: string) → Promise&lt;Payload&gt;</span>
          </div>
          <div class="pl-8">
            <span class="text-accent-2-bright">λ</span> <span class="text-text-bright">refresh</span><span class="text-muted">(rt: string) → Promise&lt;TokenPair&gt;</span>
          </div>
          <div class="term-divider"></div>
          <div>
            <span class="text-accent">342L → 48 tokens</span> <span class="text-muted">(98.6% saved)</span>
          </div>
        </div>
      </div>

      <!-- Dashboard: ctx_metrics -->
      <div class="terminal-chrome">
        <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
          <span class="terminal-dot bg-[#ff5f57]"></span>
          <span class="terminal-dot bg-[#febc2e]"></span>
          <span class="terminal-dot bg-[#28c840]"></span>
          <span class="ml-3 text-xs text-muted font-mono">ctx_metrics — session dashboard</span>
        </div>
        <div class="terminal-body px-5 py-5 font-mono space-y-3" style="font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem); line-height: 1.7;">
          <div class="flex justify-between">
            <span class="text-muted">SESSION v287</span>
            <span class="text-muted">42 min active</span>
          </div>
          <div class="term-divider"></div>
          <div class="metrics-row">
            <span class="text-text-bright">Tool calls</span>
            <span class="text-accent font-semibold">847</span>
          </div>
          <div class="metrics-row">
            <span class="text-text-bright">Tokens saved</span>
            <span class="text-accent font-semibold">412,830</span>
          </div>
          <div class="metrics-row">
            <span class="text-text-bright">Cache hits</span>
            <span class="text-accent-2 font-semibold">73%</span>
          </div>
          <div class="metrics-row">
            <span class="text-text-bright">Avg compression</span>
            <span class="text-accent-3 font-semibold">91.4%</span>
          </div>
          <div class="term-divider"></div>
          <div class="metrics-row">
            <span class="text-muted">Files cached</span>
            <span class="text-text">23</span>
          </div>
          <div class="metrics-row">
            <span class="text-muted">Re-read cost</span>
            <span class="text-text">~13 tok</span>
          </div>
          <div class="metrics-row">
            <span class="text-muted">Est. cost saved</span>
            <span class="text-accent font-semibold">$1.24</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════════════════════════════════════════════════════
     NUMBERS (now with context)
     ═══════════════════════════════════════════════════════ -->
<section class="section-y-sm">
  <div class="content-grid">
    <div class="stats-grid animate-entrance">
      <div class="stat-item">
        <span class="stat-number font-display text-accent">60–99%</span>
        <span class="stat-desc">{t('index.statsReduction')}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number font-display text-accent-2">25</span>
        <span class="stat-desc">{t('index.statsTools')}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number font-display text-accent-3">90+</span>
        <span class="stat-desc">{t('index.statsPatterns')}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number font-display text-text-bright">0</span>
        <span class="stat-desc">{t('index.statsConfig')}</span>
      </div>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════════════════════════════════════════════════════
     THREE LAYERS
     ═══════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('index.archLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('index.archTitle')}
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('index.archDesc')}
    </p>

    <div class="grid md:grid-cols-3 animate-entrance stagger-3" style="gap: clamp(1px, 0.1vw, 1px);">
      <a href={lp('/mcp-server')} class="layer-card group">
        <div class="layer-icon" style="color: var(--color-accent);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 01-3-3m3 3a3 3 0 100 6h13.5a3 3 0 100-6m-16.5-3a3 3 0 013-3h13.5a3 3 0 013 3m-19.5 0a4.5 4.5 0 01.9-2.7L5.737 5.1a3.375 3.375 0 012.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 01.9 2.7m0 0a3 3 0 01-3 3m0 3h.008v.008h-.008V18m-3 0h.008v.008h-.008V18m-3 0h.008v.008h-.008V18"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-text-bright" style="margin: 0.75rem 0;">{t('index.archServerTitle')}</h3>
        <p class="fluid-sm text-muted leading-relaxed" style="margin-bottom: 1.5rem;">
          {t('index.archServerDesc')}
        </p>
        <span class="layer-link text-accent">
          {t('index.archServerLink')}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </span>
      </a>

      <a href={lp('/shell-hook')} class="layer-card group">
        <div class="layer-icon" style="color: var(--color-accent-2);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-text-bright" style="margin: 0.75rem 0;">{t('index.archHookTitle')}</h3>
        <p class="fluid-sm text-muted leading-relaxed" style="margin-bottom: 1.5rem;">
          {t('index.archHookDesc')}
        </p>
        <span class="layer-link text-accent-2">
          {t('index.archHookLink')}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </span>
      </a>

      <a href={lp('/protocols')} class="layer-card group">
        <div class="layer-icon" style="color: var(--color-accent-3);">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/></svg>
        </div>
        <h3 class="font-display fluid-h3 font-semibold text-text-bright" style="margin: 0.75rem 0;">{t('index.archProtocolsTitle')}</h3>
        <p class="fluid-sm text-muted leading-relaxed" style="margin-bottom: 1.5rem;">
          {t('index.archProtocolsDesc')}
        </p>
        <span class="layer-link text-accent-3">
          {t('index.archProtocolsLink')}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </span>
      </a>
    </div>
  </div>
</section>

<div class="section-divider content-grid"></div>

<!-- ═══════════════════════════════════════════════════════
     ECOSYSTEM: LeanCTL
     ═══════════════════════════════════════════════════════ -->
<section class="section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('index.ecoLabel')}
    </p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('index.ecoTitle')} <span class="gradient-text">{t('index.ecoTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 4rem); max-width: 48rem;">
      {t('index.ecoDesc')}
    </p>
  </div>

  <div class="content-grid-wide">
    <div class="eco-layout animate-entrance stagger-3">
      <div class="eco-tui-glow">
        <div class="eco-tui" role="img" aria-label="LeanCTL terminal interface">
          <div class="eco-tui-chrome">
            <div class="eco-dot eco-dot-r"></div><div class="eco-dot eco-dot-y"></div><div class="eco-dot eco-dot-g"></div>
