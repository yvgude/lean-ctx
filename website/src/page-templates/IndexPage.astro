  @media (max-width: 480px) {
    .hero-proof-divider:nth-of-type(2) {
      display: none;
    }
    .hero-proof {
      gap: 0.75rem 1.25rem;
    }
  }

  /* ── Compare Cards ──────────────────────────────────── */
  .compare-card {
    border: 1px solid var(--color-border);
    border-radius: clamp(10px, 0.8vw, 14px);
    overflow: hidden;
  }
  .compare-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-bottom: 1px solid var(--color-border);
  }
  .compare-header--bad {
    background: rgba(248, 113, 113, 0.04);
    color: var(--color-danger);
  }
  .compare-header--good {
    background: rgba(52, 211, 153, 0.04);
    color: var(--color-accent);
  }
  .compare-body {
    padding: 1.25rem;
    background: var(--color-surface);
  }
  .compare-line {
    padding: 0.3rem 0;
  }

  /* ── Stats ──────────────────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--color-border);
    border: 1px solid var(--color-border);
    border-radius: clamp(10px, 0.8vw, 14px);
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .stats-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .stat-item {
    display: flex;
    flex-direction: column;
    padding: clamp(1.25rem, 1rem + 1vw, 2rem);
    background: var(--color-bg);
  }
  .stat-number {
    font-size: clamp(2rem, 1.5rem + 2vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    margin-bottom: 0.625rem;
  }
  .stat-desc {
    font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.8125rem);
    color: var(--color-muted);
    line-height: 1.5;
  }

  /* ── Layer Cards ────────────────────────────────────── */
  .layer-card {
    display: flex;
    flex-direction: column;
    padding: clamp(1.5rem, 1.25rem + 1vw, 2.5rem);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    transition: background 0.2s ease;
    text-decoration: none;
  }
  .layer-card:first-child {
    border-radius: clamp(10px, 0.8vw, 14px) clamp(10px, 0.8vw, 14px) 0 0;
  }
  .layer-card:last-child {
    border-radius: 0 0 clamp(10px, 0.8vw, 14px) clamp(10px, 0.8vw, 14px);
  }
  .layer-card + .layer-card {
    border-top: none;
  }
  @media (min-width: 768px) {
    .layer-card:first-child {
      border-radius: clamp(10px, 0.8vw, 14px) 0 0 clamp(10px, 0.8vw, 14px);
    }
    .layer-card:last-child {
      border-radius: 0 clamp(10px, 0.8vw, 14px) clamp(10px, 0.8vw, 14px) 0;
    }
    .layer-card + .layer-card {
      border-top: 1px solid var(--color-border);
      border-inline-start: none;
    }
  }
  .layer-card:hover {
    background: var(--color-surface);
  }

  .layer-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .layer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: clamp(0.6875rem, 0.65rem + 0.1vw, 0.75rem);
    font-weight: 500;
    margin-top: auto;
    transition: gap 0.2s ease;
