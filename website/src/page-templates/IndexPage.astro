  }
  .eco-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ── Ecosystem: TUI (matches leanctl.com design) ── */
  .eco-tui {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(58,57,67,.6);
    background: #201F26;
    font-family: 'JetBrains Mono', ui-monospace, monospace;
