---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';
const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title={t('mcpServer.title')} description={t('mcpServer.metaDescription')} breadcrumbs={[{ name: t('common.home'), url: lp('/') }, { name: t('mcpServer.heroLabel'), url: lp('/mcp-server/') }]}>

<!-- ═══════ HERO ═══════ -->
<section class="section-hero">
  <div class="content-grid">
    <div class="animate-entrance">
      <p class="fluid-label text-muted" style="margin-bottom: clamp(1.25rem, 1rem + 1vw, 2.5rem);">{t('mcpServer.heroLabel')}</p>
    </div>
    <h1 class="font-display fluid-h1 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1.5rem, 1rem + 1.5vw, 3rem);">
      {t('mcpServer.heroTitle')}<br/><span class="gradient-text">{t('mcpServer.heroTitleHighlight')}</span>
    </h1>
    <p class="fluid-body text-muted animate-entrance stagger-2" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 5rem); max-width: 44rem;">
      {t('mcpServer.heroDesc')}
    </p>
    <div class="animate-entrance stagger-3 flex flex-wrap items-center gap-3">
      <span class="mcp-hero-stat"><span class="text-accent font-bold">34</span> {t('mcpServer.heroStatTools')}</span>
      <span class="mcp-hero-stat"><span class="text-accent font-bold">7</span> {t('mcpServer.heroStatModes')}</span>
      <span class="mcp-hero-stat"><span class="text-accent font-bold">99%</span> {t('mcpServer.heroStatMax')}</span>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ HOW MCP WORKS ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('mcpServer.protocolLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('mcpServer.protocolTitle')} <span class="gradient-text">{t('mcpServer.protocolTitleHighlight')}</span> {t('mcpServer.protocolTitleSuffix')}
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('mcpServer.protocolDesc')}
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-0 mb-6 animate-entrance">
      <div class="mcp-flow-step">
        <div class="mcp-flow-icon" style="border-color: rgba(129,140,248,0.2); background: rgba(129,140,248,0.06);">
          <svg class="w-6 h-6 text-accent-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </div>
        <h3 class="fluid-h3 font-semibold text-text-bright mb-1 font-display">{t('mcpServer.flowAiTool')}</h3>
        <p class="fluid-sm text-muted">{t('mcpServer.flowAiToolDesc')}</p>
      </div>
      <div class="mcp-flow-step relative">
        <div class="hidden sm:block mcp-flow-arrow mcp-flow-arrow-left" aria-hidden="true"></div>
        <div class="mcp-flow-icon" style="border-color: rgba(52, 211, 153, 0.25); background: rgba(52, 211, 153, 0.08);">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
        </div>
        <h3 class="fluid-h3 font-semibold text-accent mb-1 font-display">{t('mcpServer.flowLeanCtxMcp')}</h3>
        <p class="fluid-sm text-muted">{t('mcpServer.flowLeanCtxMcpDesc')}</p>
        <div class="hidden sm:block mcp-flow-arrow mcp-flow-arrow-right" aria-hidden="true"></div>
      </div>
      <div class="mcp-flow-step">
        <div class="mcp-flow-icon" style="border-color: rgba(192,132,252,0.2); background: rgba(192,132,252,0.06);">
          <svg class="w-6 h-6 text-accent-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        </div>
        <h3 class="fluid-h3 font-semibold text-text-bright mb-1 font-display">{t('mcpServer.flowLlm')}</h3>
        <p class="fluid-sm text-muted">{t('mcpServer.flowLlmDesc')}</p>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ TOOL CATEGORIES ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('mcpServer.categoriesLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem);">
      {t('mcpServer.categoriesTitle')} <span class="gradient-text">{t('mcpServer.categoriesTitleHighlight')}</span>
    </h2>

    <div class="grid sm:grid-cols-2" style="gap: clamp(1rem, 0.75rem + 0.75vw, 1.5rem);">

      <!-- File & Code -->
      <div class="mcp-category-card card animate-entrance">
        <div class="flex items-center gap-3 mb-4">
          <div class="mcp-category-icon" style="background: rgba(52, 211, 153, 0.08); border-color: rgba(52, 211, 153, 0.15);">
            <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <div>
            <h3 class="fluid-h3 font-bold font-display text-text-bright" set:html={t('mcpServer.fileCodeTitle')} />
            <span class="text-[11px] text-accent font-mono">{t('mcpServer.fileCodeSavings')}</span>
          </div>
        </div>
        <p class="fluid-sm text-muted mb-4">
          {t('mcpServer.fileCodeDesc')}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="mcp-tool-tag">ctx_read</span>
          <span class="mcp-tool-tag">ctx_multi_read</span>
          <span class="mcp-tool-tag">ctx_tree</span>
          <span class="mcp-tool-tag">ctx_shell</span>
          <span class="mcp-tool-tag">ctx_search</span>
        </div>
      </div>

      <!-- Autonomous Intelligence Layer -->
      <div class="mcp-category-card card animate-entrance">
        <div class="flex items-center gap-3 mb-4">
          <div class="mcp-category-icon" style="background: rgba(129,140,248,0.08); border-color: rgba(129,140,248,0.15);">
            <svg class="w-5 h-5 text-accent-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
          </div>
          <div>
            <h3 class="fluid-h3 font-bold font-display text-text-bright">{t('mcpServer.autonomousTitle')}</h3>
            <span class="text-[11px] text-accent-2 font-mono">{t('mcpServer.autonomousSavings')}</span>
          </div>
        </div>
        <p class="fluid-sm text-muted mb-4">
          {t('mcpServer.autonomousDesc')}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="mcp-tool-tag">ctx_smart_read</span>
          <span class="mcp-tool-tag">ctx_delta</span>
          <span class="mcp-tool-tag">ctx_fill</span>
          <span class="mcp-tool-tag">ctx_intent</span>
          <span class="mcp-tool-tag">ctx_context</span>
          <span class="mcp-tool-tag">ctx_graph</span>
          <span class="mcp-tool-tag">ctx_dedup</span>
          <span class="mcp-tool-tag">ctx_response</span>
          <span class="mcp-tool-tag">ctx_discover</span>
          <span class="mcp-tool-tag">ctx_impact</span>
          <span class="mcp-tool-tag">ctx_architecture</span>
        </div>
      </div>

      <!-- Session & Monitoring -->
      <div class="mcp-category-card card animate-entrance">
        <div class="flex items-center gap-3 mb-4">
          <div class="mcp-category-icon" style="background: rgba(192,132,252,0.08); border-color: rgba(192,132,252,0.15);">
            <svg class="w-5 h-5 text-accent-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <div>
            <h3 class="fluid-h3 font-bold font-display text-text-bright" set:html={t('mcpServer.sessionTitle')} />
            <span class="text-[11px] text-accent-3 font-mono">{t('mcpServer.sessionSavings')}</span>
          </div>
        </div>
        <p class="fluid-sm text-muted mb-4">
          {t('mcpServer.sessionDesc')}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="mcp-tool-tag">ctx_session</span>
          <span class="mcp-tool-tag">ctx_compress</span>
          <span class="mcp-tool-tag">ctx_analyze</span>
          <span class="mcp-tool-tag">ctx_benchmark</span>
          <span class="mcp-tool-tag">ctx_metrics</span>
          <span class="mcp-tool-tag">ctx_wrapped</span>
          <span class="mcp-tool-tag">ctx_cache</span>
          <span class="mcp-tool-tag">ctx_heatmap</span>
          <span class="mcp-tool-tag">ctx_cost</span>
        </div>
      </div>

      <!-- Memory & Multi-Agent -->
      <div class="mcp-category-card card animate-entrance">
        <div class="flex items-center gap-3 mb-4">
          <div class="mcp-category-icon" style="background: rgba(251,191,36,0.08); border-color: rgba(251,191,36,0.15);">
            <svg class="w-5 h-5 text-warning" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
          </div>
          <div>
            <h3 class="fluid-h3 font-bold font-display text-text-bright" set:html={t('mcpServer.memoryTitle')} />
            <span class="text-[11px] text-warning font-mono">{t('mcpServer.memorySavings')}</span>
          </div>
        </div>
        <p class="fluid-sm text-muted mb-4">
          {t('mcpServer.memoryDesc')}
        </p>
        <div class="flex flex-wrap gap-1.5">
          <span class="mcp-tool-tag">ctx_knowledge</span>
          <span class="mcp-tool-tag">ctx_agent</span>
          <span class="mcp-tool-tag">ctx_overview</span>
          <span class="mcp-tool-tag">ctx_preload</span>
          <span class="mcp-tool-tag">ctx_task</span>
          <span class="mcp-tool-tag">ctx_share</span>
        </div>
      </div>

    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ READ MODES ═══════ -->
<section class="relative section-y">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('mcpServer.readModesLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('mcpServer.readModesTitle')} <span class="gradient-text">{t('mcpServer.readModesTitleHighlight')}</span>
    </h2>
    <p class="text-muted fluid-body animate-entrance stagger-2" style="margin-bottom: clamp(3rem, 2rem + 3vw, 6rem); max-width: 48rem;">
      {t('mcpServer.readModesDesc')}
    </p>

    <div class="animate-entrance" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 3rem);">
      <div class="rounded-lg border border-border overflow-hidden">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface/50">
              <th class="text-left px-4 sm:px-5 py-3 fluid-label text-muted font-display">{t('mcpServer.modeHeader')}</th>
              <th class="text-left px-4 sm:px-5 py-3 fluid-label text-muted font-display">{t('mcpServer.returnsHeader')}</th>
              <th class="text-left px-4 sm:px-5 py-3 fluid-label text-muted font-display">{t('mcpServer.whenHeader')}</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">full</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.fullReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.fullWhen')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">map</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.mapReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.mapWhen')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">signatures</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.sigReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.sigWhen')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">diff</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.diffReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.diffWhen')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">aggressive</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.aggReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.aggWhen')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">entropy</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.entropyReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.entropyWhen')}</td>
            </tr>
            <tr>
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">task</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.taskReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.taskWhen')}</td>
            </tr>
            <tr class="border-t border-border/30">
              <td class="px-4 sm:px-5 py-3"><code class="text-accent-2-bright bg-surface-3 px-1.5 py-0.5 rounded text-[11px] border border-border">lines:N-M</code></td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.linesReturn')}</td>
              <td class="px-4 sm:px-5 py-3 text-muted text-[13px]">{t('mcpServer.linesWhen')}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Terminal Demo -->
    <div class="animate-entrance">
      <div class="terminal-chrome">
        <div class="terminal-header flex items-center gap-2 px-4 py-2.5">
          <span class="terminal-dot bg-[#ff5f57]"></span>
          <span class="terminal-dot bg-[#febc2e]"></span>
          <span class="terminal-dot bg-[#28c840]"></span>
          <span class="text-muted text-[11px] ml-2 font-mono">ctx_read server.rs --mode map</span>
        </div>
        <div class="px-4 sm:px-6 py-4 sm:py-5">
          <pre class="text-[11px] sm:text-[13px] font-mono leading-[1.8] text-text whitespace-pre"><span class="text-accent">F1</span>=server.rs [342L]
  deps: tokio, serde, tower, axum
  exports: start_server, AppState, Config
  API:
    §  <span class="text-text-bright">AppState</span> {'{'} db: Pool, cache: Cache, config: Config {'}'}
    §  <span class="text-text-bright">Config</span> {'{'} port: u16, host: String, max_conn: usize {'}'}
    fn async <span class="text-text-bright">start_server</span>(config: Config) → Result&lt;()&gt;
    fn async <span class="text-text-bright">handle_request</span>(state: AppState, req: Request) → Response
    fn <span class="text-text-bright">configure_routes</span>(state: AppState) → Router
  <span class="text-muted/50">[2,847 tok saved (93%)]</span></pre>
        </div>
      </div>
    </div>
  </div>
</section>


<div class="section-divider content-grid"></div>


<!-- ═══════ CTA ═══════ -->
<section class="relative section-y overflow-hidden">
  <div class="content-grid">
    <p class="fluid-label text-muted animate-entrance" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">{t('mcpServer.ctaLabel')}</p>
    <h2 class="font-display fluid-h2 font-bold text-text-bright animate-entrance stagger-1" style="margin-bottom: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);">
      {t('mcpServer.ctaTitle')} <span class="gradient-text">{t('mcpServer.ctaTitleHighlight')}</span>
    </h2>
    <p class="fluid-body text-muted animate-entrance stagger-2" style="margin-bottom: clamp(2.5rem, 2rem + 2vw, 5rem); max-width: 44rem;">
      {t('mcpServer.ctaDesc')}
    </p>
    <div class="flex flex-wrap items-center gap-3 animate-entrance stagger-3">
      <a href={lp('/docs/getting-started')} class="btn-primary inline-flex items-center font-bold rounded-lg text-bg" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('common.getStarted')}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
      </a>
      <a href={lp('/docs/tools')} class="btn-outline inline-flex items-center font-medium rounded-lg text-text" style="padding: clamp(0.7rem, 0.55rem + 0.3vw, 0.9rem) clamp(1.5rem, 1rem + 0.75vw, 2.25rem); font-size: clamp(0.8125rem, 0.78rem + 0.15vw, 0.9375rem);">
        {t('mcpServer.apiReference')}
      </a>
    </div>
  </div>
</section>


<style>
  .mcp-hero-stat {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 6px 14px;
  }

  .mcp-flow-step {
    padding: 1.5rem 1rem;
  }
  .mcp-flow-icon {
    width: 56px;
    height: 56px;
    border-radius: clamp(10px, 0.8vw, 14px);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid;
    margin-bottom: 0.75rem;
  }
  .mcp-flow-arrow {
    position: absolute;
    top: 50%;
    width: 40px;
    height: 1px;
    background: var(--color-border);
  }
  .mcp-flow-arrow-left {
    left: -20px;
    transform: translateY(-12px);
  }
  .mcp-flow-arrow-right {
    right: -20px;
    transform: translateY(-12px);
  }

