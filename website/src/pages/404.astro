---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — lean-ctx">
  <div class="relative max-w-xl mx-auto px-6 py-40 text-center">
    <div class="relative">
      <p class="text-8xl font-extrabold text-accent mb-6">404</p>
      <h1 class="text-2xl font-bold mb-4 text-text-bright">Page Not Found</h1>
      <p class="text-muted mb-10">The page you're looking for doesn't exist or has been moved.</p>
      <a href="/" class="btn-glossy inline-flex items-center px-8 py-3.5 text-sm font-bold rounded-xl text-bg">
        Back to Home
      </a>
    </div>
  </div>
</BaseLayout>
