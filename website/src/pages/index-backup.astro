---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ProblemCards from '../components/ProblemCards.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import TerminalShowcase from '../components/TerminalShowcase.astro';
import FeatureCards from '../components/FeatureCards.astro';
import PowerFeatures from '../components/PowerFeatures.astro';
import ProtocolSection from '../components/ProtocolSection.astro';
import VisionSection from '../components/VisionSection.astro';
import CompatibilitySection from '../components/CompatibilitySection.astro';
import QuickStart from '../components/QuickStart.astro';
---

<BaseLayout title="LeanCTX — Cut Token Costs, Extend API Limits" description="Reduce LLM token consumption by up to 99%. Make API rate limits last longer, lower your AI coding costs. MCP server + shell hook + 90+ CLI patterns + 24 MCP tools + persistent project graph. Single Rust binary, open source." noindex={true}>

  <Hero />

  <ProblemCards />

  <div class="section-divider max-w-5xl mx-auto"></div>

  <BeforeAfter />

  <TerminalShowcase />

  <div class="section-divider max-w-5xl mx-auto"></div>

  <FeatureCards />

  <div class="section-divider max-w-5xl mx-auto"></div>

  <PowerFeatures />

  <div class="section-divider max-w-5xl mx-auto"></div>

  <ProtocolSection />

  <VisionSection />

  <CompatibilitySection />

  <div class="section-divider max-w-5xl mx-auto"></div>

  <QuickStart />

  <!-- Final CTA -->
  <section class="relative py-24 sm:py-36 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-radial-[at_50%_100%] from-accent/[0.04] to-transparent"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-[11px] font-medium uppercase tracking-[0.2em] text-accent mb-4">Open Source, Free, Local</p>
      <h2 class="font-display text-2xl sm:text-[2.75rem] font-bold tracking-tight leading-[1.1] text-text-bright mb-4">
        Stop wasting tokens. <span class="gradient-text-green">Start saving.</span>
      </h2>
      <p class="text-sm text-muted leading-relaxed mb-4 max-w-md mx-auto">
        Make every token count. Extend your limits. Cut your costs. One binary, zero cloud dependencies.
      </p>
      <div class="flex justify-center gap-6 mb-8 text-xs font-mono text-muted">
        <span class="text-accent">Single Rust binary</span>
        <span class="text-accent">MIT licensed</span>
        <span class="text-accent">No cloud</span>
      </div>
      <div class="flex flex-col sm:flex-row justify-center gap-3">
        <a href="/docs/getting-started" class="btn-glossy inline-flex items-center justify-center px-8 py-3.5 text-sm font-bold rounded-xl text-bg">
          Get Started Free
        </a>
        <a href="https://github.com/yvgude/lean-ctx" target="_blank" rel="noopener" class="btn-outline-glossy inline-flex items-center justify-center px-8 py-3.5 text-sm font-medium rounded-xl text-text">
          <svg class="mr-2 w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
