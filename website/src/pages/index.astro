<script is:inline>
(function() {
  var installEl = document.getElementById('install-count');
  var starsEl = document.getElementById('github-stars-hero');
  var installs = 0;
  var installsDone = 0;

  function countUp(el, target, duration) {
    var start = 0;
    var startTime = null;
    function step(ts) {
      if (!startTime) startTime = ts;
      var progress = Math.min((ts - startTime) / duration, 1);
      var ease = 1 - Math.pow(1 - progress, 3);
      var current = Math.floor(ease * target);
      el.textContent = current.toLocaleString('en-US');
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  function updateInstalls() {
    installsDone++;
    if (installsDone >= 3 && installs > 0 && installEl) {
      countUp(installEl, installs, 1200);
    }
  }

  fetch('https://crates.io/api/v1/crates/lean-ctx')
    .then(function(r) { return r.json(); })
    .then(function(d) { installs += d.crate.downloads || 0; updateInstalls(); })
    .catch(updateInstalls);

  fetch('https://api.npmjs.org/downloads/point/last-year/lean-ctx-bin')
    .then(function(r) { return r.json(); })
    .then(function(d) { installs += d.downloads || 0; updateInstalls(); })
    .catch(updateInstalls);

  fetch('https://api.github.com/repos/yvgude/lean-ctx/releases')
    .then(function(r) { return r.json(); })
    .then(function(releases) {
      if (Array.isArray(releases)) {
        for (var i = 0; i < releases.length; i++) {
          var assets = releases[i].assets || [];
          for (var j = 0; j < assets.length; j++) {
            installs += assets[j].download_count || 0;
          }
        }
      }
      updateInstalls();
    })
    .catch(updateInstalls);

  if (starsEl) {
    fetch('https://api.github.com/repos/yvgude/lean-ctx')
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (d.stargazers_count) countUp(starsEl, d.stargazers_count, 1000);
      })
      .catch(function() {});
  }
})();
</script>

</BaseLayout>
