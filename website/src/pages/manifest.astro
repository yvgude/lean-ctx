<style>
  .manifest-toc-link.active {
    color: var(--color-accent);
    background: rgba(52, 211, 153, 0.06);
  }
  .manifest-toc-link.active::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    bottom: 4px;
    width: 2px;
    background: var(--color-accent);
    border-radius: 1px;
  }
  .manifest-toc-link {
    position: relative;
  }

  .manifest-mobile-nav {
    background: var(--color-surface);
    border: 1px solid rgba(26, 26, 48, 0.5);
    border-radius: 12px;
  }
  .manifest-mobile-nav summary {
    list-style: none;
  }
  .manifest-mobile-nav summary::-webkit-details-marker {
    display: none;
  }
  .manifest-mobile-nav[open] {
    border-color: rgba(52, 211, 153, 0.15);
  }
</style>

<script>
  const links = document.querySelectorAll('.manifest-toc-link');
  const sections = document.querySelectorAll('article section[id]');

  function updateActive() {
    let current = '';
    sections.forEach(s => {
      const rect = s.getBoundingClientRect();
      if (rect.top <= 120) current = s.id;
    });
    links.forEach(l => {
      l.classList.toggle('active', l.getAttribute('href') === `#${current}`);
    });
  }

  window.addEventListener('scroll', updateActive, { passive: true });
  updateActive();
</script>
